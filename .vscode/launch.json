    "version": "0.2.0",
    "configurations": [
        {
            "type": "lua",
            "request": "launch",
            "name": "File Debug",
            "console": "internalConsole",
            "outputCapture": [
                "stdout",
                "stderr"
            ],
            "luaVersion": "lua53",
            "program": "${file}"
        },
        {
            "type": "lua",
            "request": "launch",
            "name": "Tests Debug",
            "console": "internalConsole",
            "outputCapture": [
                "stdout",
                "stderr"
            ],
            "luaVersion": "lua53",
            "program": "${workspaceFolder}/test/main.lua"
        }
    ]
}