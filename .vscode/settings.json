{
    "lua.debug.settings.luaVersion": "lua53",
    "lua.debug.settings.path": "${workspaceFolder}/?.lua;${workspaceFolder}/mock/?.lua;${workspaceFolder}/test/?.lua;${workspaceFolder}/src/?.lua",
    "Lua.workspace.library": [
        "${workspaceFolder}/src",
        "${workspaceFolder/mock"
    ],
    "[lua]": {
        "editor.defaultFormatter": "JohnnyMorganz.stylua",
        "editor.formatOnSave": true
    },
    "stylua.configPath": "${workspaceFolder}/.stylua.toml",
    "stylua.searchParentDirectories": true,
    "stylua.searchBinaryInPATH": true,
}